# discord-notify.py runtime config. Copy to .notify.env and fill in real values.
# .notify.env is gitignored. sync.sh passes this through to the container via
# `podman run --env-file`.

NOTIFY_IMAP_HOST=mail.example.com
NOTIFY_IMAP_PORT=1143
NOTIFY_IMAP_USER=you@example.com
NOTIFY_IMAP_FOLDER=INBOX

# Subject-side id extraction. Optional. If your helpdesk embeds an id like
# `[TICKET-123456]` in the Subject, set both:
#   - NOTIFY_TICKET_ID_RE   one-capture-group regex matched against Subject
#   - NOTIFY_TICKET_URL_FMT format string with `{}` for the captured id
# Example for a Freshservice instance using a `[QUERY-NNN]` prefix:
# NOTIFY_TICKET_ID_RE=\[QUERY-(\d+)\]
# NOTIFY_TICKET_URL_FMT=https://support.example.edu/helpdesk/tickets/{}

# Body-side fallback. Optional. Run against the first 4 KB of the message
# body when the subject regex misses. Match the full URL.
# NOTIFY_TICKET_URL_RE=https://support\.example\.edu/helpdesk/tickets/\d+
